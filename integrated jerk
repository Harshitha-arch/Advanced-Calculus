import pandas as pd
import numpy as np
from scipy.signal import savgol_filter


# STEP 1 — Load CSV
df = pd.read_csv("1.csv")

print("CSV loaded successfully.")
print(df.head())


# STEP 2 — Integrated Jerk Function (full explanation)
def compute_integrated_jerk(x, y, dt=0.01, smooth_window=21, polyorder=3):
    """
    Computes integrated jerk of 2D motion.

    Jerk = third derivative of position.
    
    Integrated Jerk = ∫ |jerk(t)| dt

    Parameters:
        x, y          : arrays of positions
        dt            : sampling interval
        smooth_window : for Savitzky–Golay filtering
        polyorder     : polynomial degree

    Returns:
        integrated_jerk : total jerk over the whole trial
        jerk_ts         : jerk time series (magnitude)
    """

    # Smoothing for stable derivatives
    x_s = savgol_filter(x, smooth_window, polyorder)
    y_s = savgol_filter(y, smooth_window, polyorder)

    # First derivative
    dx = np.gradient(x_s, dt)
    dy = np.gradient(y_s, dt)

    # Second derivative
    ddx = np.gradient(dx, dt)
    ddy = np.gradient(dy, dt)

    # Third derivative (jerk)
    dddx = np.gradient(ddx, dt)
    dddy = np.gradient(ddy, dt)

    # Jerk magnitude
    jerk_ts = np.sqrt(dddx**2 + dddy**2)

    # Integrated jerk over time
    integrated_jerk = np.sum(jerk_ts) * dt

    return integrated_jerk, jerk_ts



# STEP 3 — Apply integrated jerk to all CoP trajectories

pairs = [('X1','Z1'), ('X3','Z3'), ('X5','Z5'), ('X7','Z7')]
jerk_results = {}

for x_col, z_col in pairs:
    x = df[x_col].values
    y = df[z_col].values

    total_jerk, jerk_series = compute_integrated_jerk(x, y)

    jerk_results[f"{x_col}_{z_col}"] = {
        "integrated_jerk": total_jerk,
        "mean_jerk": np.mean(jerk_series),
        "max_jerk": np.max(jerk_series)
    }


# STEP 4 — Print results clearly

print("\n===== INTEGRATED JERK RESULTS =====")
for trial, values in jerk_results.items():
    print(f"\nTrajectory {trial}:")
    print(f"Integrated jerk : {values['integrated_jerk']:.6f}")
    print(f"Mean jerk       : {values['mean_jerk']:.6f}")
    print(f"Max jerk        : {values['max_jerk']:.6f}")
